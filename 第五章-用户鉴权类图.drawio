<mxfile host="app.diagrams.net" modified="2026-04-27T22:35:00.000Z" agent="Mozilla/5.0" version="22.1.0">
  <diagram id="uml-user-auth-v2" name="UML - User & Auth (Aligned v2)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="UML 类图：用户与认证模块" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="20" width="760" height="40" as="geometry"/>
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="说明：采用等宽字体 + 三段式（类名 / 属性 / 方法）展示，接口用 &lt;&lt;interface&gt;&gt; 标注，实现关系为虚线三角。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=12;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="1280" height="40" as="geometry"/>
        </mxCell>

        <!-- Classes -->
        <mxCell id="UserController" value="UserController&#xa;--------------------&#xa;+ userService : UserService&#xa;--------------------&#xa;+ login(dto : UserLoginDto) : Result&#xa;+ register(dto : UserRegisterDto) : Result&#xa;+ auth() : Result&#xa;+ update(dto : UserUpdateDto) : Result&#xa;+ updatePassword(dto : UserUpdatePasswordDto) : Result&#xa;+ query(dto : UserQueryDto) : Result" style="rounded=0;whiteSpace=wrap;=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="380" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="UserService" value="&lt;&lt;interface&gt;&gt; UserService&#xa;--------------------&#xa;（无成员属性）&#xa;--------------------&#xa;+ login(dto : UserLoginDto) : TokenVO&#xa;+ register(dto : UserRegisterDto) : void&#xa;+ auth() : UserVO&#xa;+ update(dto : UserUpdateDto) : void&#xa;+ updatePassword(dto : UserUpdatePasswordDto) : void" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="500" y="140" width="390" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="UserService" value="UserServiceImpl&#xa;--------------------&#xa;- userMapper : UserMapper&#xa jwtUtil : JwtUtil&#xa;- threadHolder : LocalThreadHolder&#xa;--------------------&#xa;+ login(dto : UserLoginDto) : TokenVO&#xa;+(dto : UserRegisterDto) : void&#xa;+ auth() : UserVO&#xa;+ update(dto : UserUpdateDto) : void&#xa;+ updatePassword(dto : UserUpdatePasswordDto) : void" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="500" y="390" width="390" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="UserMapper" value="&lt;&lt;DAO&gt;&gt; UserMapper&#xa;--------------------&#xa;（无成员属性）&#xa;--------------------&#xa;+ getUserByAccount(account : String) : User&#xa;+ getUserById(id : Integer) : User&#xa;+ save(u : User) : int&#xa;+ update(u : User) : int" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="940" y="390" width="400" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="JwtUtil" value="JwtUtil&#xa;--------------------&#xa;（无成员属性）&#xa--------------------&#xa;+ toToken(userId : Integer, role : Integer) : String&#xa;+ fromToken(token : String) : JwtPayload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="940" y="140" width="400" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="JwtInterceptor" value="JwtInterceptor&#xa;--------------------&#xa;（无成员属性）&#xa;--------------------&#xa;+ preHandle(req, res, handler) : boolean&#xa;+ afterCompletion(req, res, handler, ex) : void" style="rounded=0;white=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="940" y="310" width="400" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="LocalThreadHolder" value="LocalThreadHolder&#xa;--------------------&#xa;（线程上下文变量）&#xa;--------------------&#xa;+ setUser(id : Integer, role : Integer) : void&#xa;+ getUserId() : Integer&#xa;+ getRole() :&#xa;+ clear() : void" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontStyle=1;fontFamily=Courier New;align=left;verticalAlign=top" vertex="1 parent="1">
          <mxGeometry x="940" y="620" width="400" height="170" as="geometry"/>
        </mxCell>

        <!-- Relations -->
        <!-- Controller -> Service -->
        <mxCell id="e1" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#2F5597" edge="1" parent="1" source="UserController" target="UserService">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ServiceImpl implements Service (dashed + hollow triangle) -->
        <mxCell id="e2" value="implements" style="endArrow=block;endFill=0;endSize=14;html=1;strokeWidth=2;dashed=1;strokeColor=#7F6000" edge="1" parent="1" source="UserService" target="UserService">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ServiceImpl -> Mapper/JwtUtil/ThreadHolder -->
        <mxCell id="e3" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#385723" edge="1" parent="1" source="UserServiceImpl target="UserMapper">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="UserServiceImpl" target="JwtUtil">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="UserServiceImpl" target="LocalThreadHolder">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Interceptor -> JwtUtil / ThreadHolder -->
       mxCell id="e6" style="endArrow=blockhtml=1;strokeWidth=2;strokeColor=#B85450" edge="1" parent="1" source="JwtInterceptor" target="JwtUtil">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#B85450" edge="1" parent="1" source="JwtInterceptor target="LocalThreadHolder">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
