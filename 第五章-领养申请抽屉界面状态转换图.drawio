        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7EA;strokeColor=#82B366;align=left" value="组件：Mapper（DAO）/ Entity&#xa;技术：MyBatis-Plus（mybatis-plus-boot-starter 3.5.3.1）&#xa;数据库：MySQL（mysql-connector-java）" vertex="1">
          <mxGeometry height="70" width="960" x="395" y="869" as="geometry" />
        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontStyle=1;align=left" value="" vertex="1">
