        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-22" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2" value="调用方向：Controller → Service → Mapper → DB（基础设施层被各层复用）" vertex="1">
          <mxGeometry height="30" width="1000" x="371" y="1175" as="geometry" />
        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-23" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-weight: 700;&quot;&gt;表示层（Presentation Layer）&lt;/span&gt;&lt;br style=&quot;font-weight: 700;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;职责：接收HTTP请求、参数绑定/校验、调用Service、封装响应Result&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="528" x="572" y="506" as="geometry" />
        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-24" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-weight: 700; text-align: left;&quot;&gt;业务逻辑层（Business Layer）&lt;/span&gt;&lt;br style=&quot;font-weight: 700; text-align: left;&quot;&gt;&lt;span style=&quot;font-weight: 700; text-align: left;&quot;&gt;职责：实现业务规则、事务控制、聚合计算、调用DAO/Mapper&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="357" x="692.5" y="660" as="geometry" />
        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-25" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-weight: 700; text-align: left;&quot;&gt;数据访问层（Data Access Layer）&lt;/span&gt;&lt;br style=&quot;font-weight: 700; text-align: left;&quot;&gt;&lt;span style=&quot;font-weight: 700; text-align: left;&quot;&gt;职责：与数据库交互、执行CRUD、实体映射&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="306" x="708" y="833" as="geometry" />
        </mxCell>
        <mxCell id="tvgjND9s9JvuRawVZcP6-26" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-weight: 700; text-align: left;&quot;&gt;基础设施/通用层（Infrastructure Layer）&lt;/span&gt;&lt;br style=&quot;font-weight: 700; text-align: left;&quot;&gt;&lt;span style=&quot;font-weight: 700; text-align: left;&quot;&gt;职责：通用工具、配置、拦截器、第三方集成&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="393" x="664.5" y="969" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
