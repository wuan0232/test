<mxfile host="app.diagrams.net" agent="Mozilla/5.0">
  <diagram id="login-flow" name="Login Flow">
    <mxGraphModel dx="2808" dy="972" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" value="用户登录流程（操作步骤-界面反馈-请求时机-异常处理）" vertex="1">
          <mxGeometry height="40" width="960" x="-302" y="10" as="geometry" />
        </mxCell>
        <mxCell id="s" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="开始&#xa;访问登录页" vertex="1">
          <mxGeometry height="60" width="220" x="60" y="70" as="geometry" />
        </mxCell>
        <mxCell id="i" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="用户输入&#xa;账号 + 密码" vertex="1">
          <mxGeometry height="70" width="220" x="60" y="170" as="geometry" />
        </mxCell>
        <mxCell id="v" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontStyle=1" value="表单校验&#xa;（必填/格式）" vertex="1">
          <mxGeometry height="110" width="170" x="85" y="310" as="geometry" />
        </mxCell>
        <mxCell id="vFail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="提示：账号或密码不能为空&#xa;（不发请求）" vertex="1">
          <mxGeometry height="70" width="260" x="310" y="450" as="geometry" />
        </mxCell>
        <mxCell id="enc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="密码处理&#xa;双重 MD5 加密" vertex="1">
          <mxGeometry height="70" width="220" x="60" y="450" as="geometry" />
        </mxCell>
        <mxCell id="req" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="发送请求&#xa;POST /user/login" vertex="1">
          <mxGeometry height="70" width="220" x="60" y="560" as="geometry" />
        </mxCell>
        <mxCell id="loading" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="界面反馈：加载态&#xa;禁用输入/按钮 + Loading" vertex="1">
          <mxGeometry height="70" width="260" x="-220" y="450" as="geometry" />
        </mxCell>
        <mxCell id="resp" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontStyle=1" value="响应判断" vertex="1">
          <mxGeometry height="110" width="170" x="85" y="660" as="geometry" />
        </mxCell>
        <mxCell id="netErr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="网络异常/超时&#xa;提示：登录失败&#xa;恢复可编辑" vertex="1">
          <mxGeometry height="90" width="260" x="-540" y="380" as="geometry" />
        </mxCell>
        <mxCell id="bizErr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="账号或密码错误&#xa;提示错误信息&#xa;恢复可编辑" vertex="1">
          <mxGeometry height="90" width="260" x="606" y="405" as="geometry" />
        </mxCell>
        <mxCell id="save" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="保存登录信息&#xa;Token / Role / UserInfo&#xa;（localStorage）" vertex="1">
          <mxGeometry height="90" width="220" x="57" y="805" as="geometry" />
        </mxCell>
        <mxCell id="role" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontStyle=1" value="角色判断" vertex="1">
          <mxGeometry height="110" width="170" x="345" y="795" as="geometry" />
        </mxCell>
        <mxCell id="toAdmin" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="跳转：管理端首页&#xa;/admin" vertex="1">
          <mxGeometry height="60" width="220" x="550" y="680" as="geometry" />
        </mxCell>
        <mxCell id="toUser" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="跳转：用户端首页&#xa;/user" vertex="1">
          <mxGeometry height="60" width="220" x="570" y="935" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="结束&#xa;登录完成" vertex="1">
          <mxGeometry height="60" width="200" x="830" y="800" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="s" style="endArrow=block;html=1;strokeWidth=2" target="i">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="i" style="endArrow=block;html=1;strokeWidth=2" target="v">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="v" style="endArrow=block;html=1;strokeWidth=2" target="vFail" value="失败">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="vFail" style="endArrow=block;html=1;strokeWidth=2;dashed=1" target="i" value="返回输入">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="v" style="endArrow=block;html=1;strokeWidth=2" target="enc" value="通过">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="enc" style="endArrow=block;html=1;strokeWidth=2" target="req">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="req" style="endArrow=block;html=1;strokeWidth=2" target="loading" value="进入加载态">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="req" style="endArrow=block;html=1;strokeWidth=2" target="resp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="resp" style="endArrow=block;html=1;strokeWidth=2" target="netErr" value="网络错误">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" edge="1" parent="1" source="resp" style="endArrow=block;html=1;strokeWidth=2" target="bizErr" value="登录失败">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" edge="1" parent="1" source="resp" style="endArrow=block;html=1;strokeWidth=2" target="save" value="成功">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="netErr" style="endArrow=block;html=1;strokeWidth=2;dashed=1" target="i" value="返回输入">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" edge="1" parent="1" source="bizErr" style="endArrow=block;html=1;strokeWidth=2;dashed=1" target="i" value="返回输入">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" edge="1" parent="1" source="save" style="endArrow=block;html=1;strokeWidth=2" target="role">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" edge="1" parent="1" source="role" style="endArrow=block;html=1;strokeWidth=2" target="toAdmin" value="管理员">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" edge="1" parent="1" source="role" style="endArrow=block;html=1;strokeWidth=2" target="toUser" value="普通用户">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e17" edge="1" parent="1" source="toAdmin" style="endArrow=block;html=1;strokeWidth=2" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e18" edge="1" parent="1" source="toUser" style="endArrow=block;html=1;strokeWidth=2" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
