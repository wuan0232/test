<mxfile host="app.diagrams.net" modified="2026-04-27T19:25:00.000Z" agent="Mozilla/5.0" version="22.1.0">
  <diagram id="adopt-flow" name="Adopt Apply Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="t" value="宠物领养申请流程（多步骤表单：操作-反馈-请求时机-异常处理）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="180" y="20" width="1040" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="s" value="开始&#xa;用户浏览宠物详情" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="240" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="click" value="点击“申请领养”" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF" vertex="1" parent="1">
          <mxGeometry x="60" y="190" width="240" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="open" value="界面反馈：打开抽屉&#xa;初始化 step=1&#xa;请求地址列表（GET）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="240" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="step1" value="步骤一：确认宠物信息&#xa;（仅展示，不发请求）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="to2" value="下一步" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656" vertex="1" parent="1">
          <mxGeometry x="100" y="475" width="160" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="step2" value="步骤二：填写领养材料&#xa;（Editor 富文本）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="360" y="380" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="check2" value="材料是否为空？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656" vertex="1" parent="1">
          <mxGeometry x="410" y="475" width="160" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="err2" value="提示：请补充证明材料&#xa;停留步骤二&#xa;（不发请求）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="660" y="490" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="step3" value="步骤三：选择收货地址&#xa;（从列表中选择）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="360" y="580" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="check3" value="是否已选择地址？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656" vertex="1" parent="1">
          <mxGeometry x="410" y="680" width="160" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="err3" value="提示：请选择收货地址&#xa;停留步骤三&#xa;（不发请求）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="660" y="690" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="submit" value="提交申请（请求时机）&#xa;POST /pet-adopt-order/save" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2F0D9;strokeColor=#385723;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="360" y="790" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="resp" value="提交结果" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656" vertex="1" parent="1">
          <mxGeometry x="660" y="790" width="160" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="fail" value="失败：提示错误&#xa;保持抽屉打开&#xa;允许重试" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="860" y="790" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="ok" value="成功：提示提交成功&#xa;关闭抽屉&#xa;刷新详情/跳转订单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="860" y="880" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="s" target="click"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="click" target="open"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="open" target="step1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="下一步" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="step1" target="to2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="进入步骤二" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="to2" target="step2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="点击下一步" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="step2" target="check2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e7" value="为空" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="check2" target="err2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="返回编辑" style="endArrow=block;html=1;strokeWidth=2;dashed=1" edge="1" parent="1" source="err2" target="step2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e9" value="不为空" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="check2" target="step3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e10" value="点击提交前校验" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="step3" target="check3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" value="未选择" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="check3" target="err3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" value="返回选择" style="endArrow=block;html=1;strokeWidth=2;dashed=1" edge="1" parent="1" source="err3" target="step3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e13" value="已选择" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="check3" target="submit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="submit" target="resp"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e15" value="失败" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="resp" target="fail"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e16" value="成功" style="endArrow=block;html=1;strokeWidth=2" edge="1" parent="1" source="resp" target="ok"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
