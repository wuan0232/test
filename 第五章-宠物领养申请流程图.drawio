<mxfile host="app.diagrams.net" agent="Mozilla/5.0">
  <diagram id="adopt-flow" name="Adopt Apply Flow">
    <mxGraphModel dx="1408" dy="972" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" value="宠物领养申请流程（多步骤表单：操作-反馈-请求时机-异常处理）" vertex="1">
          <mxGeometry height="40" width="1040" x="48" y="13" as="geometry" />
        </mxCell>
        <mxCell id="s" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="开始&#xa;用户浏览宠物详情" vertex="1">
          <mxGeometry height="60" width="240" x="60" y="110" as="geometry" />
        </mxCell>
        <mxCell id="click" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="点击“申请领养”" vertex="1">
          <mxGeometry height="60" width="240" x="60" y="190" as="geometry" />
        </mxCell>
        <mxCell id="open" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="界面反馈：打开抽屉&#xa;初始化 step=1&#xa;请求地址列表（GET）" vertex="1">
          <mxGeometry height="90" width="240" x="60" y="270" as="geometry" />
        </mxCell>
        <mxCell id="step1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="步骤一：确认宠物信息&#xa;（仅展示，不发请求）" vertex="1">
          <mxGeometry height="80" width="240" x="60" y="380" as="geometry" />
        </mxCell>
        <mxCell id="to2" parent="1" style="rhombus;whiteSpace=wrap;html=1;" value="下一步" vertex="1">
          <mxGeometry height="90" width="160" x="390" y="370" as="geometry" />
        </mxCell>
        <mxCell id="step2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="步骤二：填写领养材料&#xa;（Editor 富文本）" vertex="1">
          <mxGeometry height="80" width="260" x="668" y="375" as="geometry" />
        </mxCell>
        <mxCell id="check2" parent="1" style="rhombus;whiteSpace=wrap;html=1;" value="材料是否为空？" vertex="1">
          <mxGeometry height="90" width="160" x="390" y="475" as="geometry" />
        </mxCell>
        <mxCell id="err2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="提示：请补充证明材料&#xa;停留步骤二&#xa;（不发请求）" vertex="1">
          <mxGeometry height="80" width="260" x="670" y="494" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="步骤三：选择收货地址&#xa;（从列表中选择）" vertex="1">
          <mxGeometry height="80" width="260" x="55" y="480" as="geometry" />
        </mxCell>
        <mxCell id="check3" parent="1" style="rhombus;whiteSpace=wrap;html=1;" value="是否已选择地址？" vertex="1">
          <mxGeometry height="90" width="160" x="105" y="612" as="geometry" />
        </mxCell>
        <mxCell id="err3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="提示：请选择收货地址&#xa;停留步骤三&#xa;（不发请求）" vertex="1">
          <mxGeometry height="80" width="260" x="670" y="612" as="geometry" />
        </mxCell>
        <mxCell id="submit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="提交申请（请求时机）&#xa;POST /pet-adopt-order/save" vertex="1">
          <mxGeometry height="70" width="260" x="55" y="786" as="geometry" />
        </mxCell>
        <mxCell id="resp" parent="1" style="rhombus;whiteSpace=wrap;html=1;" value="提交结果" vertex="1">
          <mxGeometry height="90" width="160" x="417" y="772" as="geometry" />
        </mxCell>
        <mxCell id="fail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="失败：提示错误&#xa;保持抽屉打开&#xa;允许重试" vertex="1">
          <mxGeometry height="80" width="240" x="685" y="712" as="geometry" />
        </mxCell>
        <mxCell id="ok" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1" value="成功：提示提交成功&#xa;关闭抽屉&#xa;刷新详情/跳转订单" vertex="1">
          <mxGeometry height="80" width="240" x="688" y="835" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="s" style="endArrow=block;html=1;strokeWidth=2" target="click">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="click" style="endArrow=block;html=1;strokeWidth=2" target="open">
          <mxGeometry relative="1" as="geometry" />
