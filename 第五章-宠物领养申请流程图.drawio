        <mxCell id="e3" edge="1" parent="1" source="open" style="endArrow=block;html=1;strokeWidth=2" target="step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="step1" style="endArrow=block;html=1;strokeWidth=2" target="to2" value="下一步">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="to2" style="endArrow=block;html=1;strokeWidth=2" target="step2" value="进入步骤二">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="step2" style="endArrow=block;html=1;strokeWidth=2" target="check2" value="点击下一步">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="check2" style="endArrow=block;html=1;strokeWidth=2" target="err2" value="为空">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="err2" style="endArrow=block;html=1;strokeWidth=2;dashed=1" target="step2" value="返回编辑">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="check2" style="endArrow=block;html=1;strokeWidth=2" target="step3" value="不为空">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" edge="1" parent="1" source="step3" style="endArrow=block;html=1;strokeWidth=2" target="check3" value="点击提交前校验">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" edge="1" parent="1" source="check3" style="endArrow=block;html=1;strokeWidth=2" target="err3" value="未选择">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="err3" style="endArrow=block;html=1;strokeWidth=2;dashed=1" target="step3" value="返回选择">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" edge="1" parent="1" source="check3" style="endArrow=block;html=1;strokeWidth=2" target="submit" value="已选择">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" edge="1" parent="1" source="submit" style="endArrow=block;html=1;strokeWidth=2" target="resp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" edge="1" parent="1" source="resp" style="endArrow=block;html=1;strokeWidth=2" target="fail" value="失败">
